<Window x:Class="Underlit.UI.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Width="360"
        Height="180"
        Opacity="0"
        WindowStartupLocation="Manual"
        Title="Underlit">
    <!--
        Layout strategy:
          • The actual VISIBLE flyout is a Border, 260x44, with its Clip set in code to
            a squircle Path (continuous-curvature rounded rect, iOS-ish). Using Border
            instead of a Path-as-background avoids WPF's flaky Stretch/layout behavior
            for Path elements — Border's size is unambiguously its explicit Width/Height.
          • The Border sits in a much larger (360x130) Flyout Grid so its DropShadow's
            blur has transparent room on every side to fade into cleanly — without the
            blur being clipped to the Border's own 260x44 bounding box.
          • The window is 360x180 with its bottom edge pinned to the top of the taskbar,
            giving the slide-out animation room to clip against the window edge (reads as
            "sliding behind the taskbar").
    -->
    <Grid x:Name="WindowRoot">
        <Grid x:Name="Flyout"
              Width="360" Height="130"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,20,0,0"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" Y="96"/>
            </Grid.RenderTransform>

            <!-- Background: Border with standard circular-arc corners — same style Windows'
                 native flyout uses. Drop shadow is attached in code so its opacity can follow
                 the theme. -->
            <Border x:Name="BackgroundBorder"
                    Width="260" Height="44"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#EE1F1F1F"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"/>

            <!-- Content overlay: same size & position as the Border. -->
            <Grid Width="260" Height="44"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="12,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="22" Height="22"
                          VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock x:Name="IconText"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Text="&#xE706;"/>
                        <Path x:Name="CandleIcon"
                              Visibility="Collapsed"
                              Fill="#FFFFFFFF"
                              Stretch="Uniform"
                              Width="22" Height="22"
                              VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path.Data>
                                <GeometryGroup FillRule="Nonzero">
                                    <PathGeometry>
                                        <PathFigure StartPoint="7,0.5" IsClosed="True">
                                            <BezierSegment Point1="10.5,2.5" Point2="10.5,5.5" Point3="7,6.5"/>
                                            <BezierSegment Point1="3.5,5.5" Point2="3.5,2.5" Point3="7,0.5"/>
                                        </PathFigure>
                                    </PathGeometry>
                                    <RectangleGeometry Rect="6.55,6.5,0.9,2"/>
                                    <RectangleGeometry Rect="4.75,8.5,4.5,9" RadiusX="0.8" RadiusY="0.8"/>
                                </GeometryGroup>
                            </Path.Data>
                        </Path>
                    </Grid>

                    <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                          Height="4" x:Name="BarRoot">

                        <Grid x:Name="BrightnessBar">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="TrackLeft"  Grid.Column="0" CornerRadius="2,0,0,2" Background="#33FFFFFF"/>
                            <Border Grid.Column="0" x:Name="FillLeft"
                                    HorizontalAlignment="Right" CornerRadius="2,0,0,2"
                                    Background="#FFE5B675" Width="0"/>
                            <Border x:Name="TrackRight" Grid.Column="1" CornerRadius="0,2,2,0" Background="#33FFFFFF"/>
                            <Border Grid.Column="1" x:Name="FillRight"
                                    HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                                    Background="#FFFFFFFF" Width="0"/>
                            <Border x:Name="MidMarker"
                                    Grid.ColumnSpan="2"
                                    Width="2" Height="14"
                                    Background="#B3FFFFFF"
                                    CornerRadius="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="WarmthBar" Visibility="Collapsed">
                            <Border x:Name="WarmthTrack" CornerRadius="2" Background="#33FFFFFF"/>
                            <Border x:Name="WarmthFill"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Width="0">
                                <Border.Background>
                                    <LinearGradientBrush x:Name="WarmthGradient"
                                                         StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop x:Name="WarmthStartStop" Offset="0" Color="#FFFF5A00"/>
                                        <GradientStop x:Name="WarmthEndStop"   Offset="1" Color="#FFFFF9FB"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
