<Window x:Class="Underlit.UI.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        Width="300"
        Height="160"
        Opacity="0"
        WindowStartupLocation="Manual"
        Title="Underlit">
    <!--
        Layout strategy (v0.3 rewrite):
          • Window is 300x66 with AllowsTransparency=true. The visible pill is 280x46
            inside, with a 10px margin all around so we can render a soft shadow halo
            into the captured-image's alpha channel without it being clipped at the
            window boundary. Apple's pills ride on a soft elevation shadow — DWM's
            window shadow doesn't behave well with layered windows and only works
            with rectangular outlines, so we do it ourselves.
          • CornerRadius=23 on every visible layer = full pill (height/2). DWM's
            8px rounding doesn't apply when AllowsTransparency=true; the corners come
            from our own renderer's alpha mask.
          • No DWM acrylic in this mode — the renderer draws the entire glass body
            including refraction, Phong specular, Fresnel rim, and the soft shadow.
    -->

    <!-- Background="Transparent" (not null) so the empty pixels of the Grid are still
         hit-testable — the brightness mouse-drag handler relies on PreviewMouseDown
         firing across the full pill area, not just on opaque child elements.
         WindowRoot is 300×160 (window height). The visible PillContainer below is
         pinned to the TOP 66 dip; the bottom 94 dip is empty space that the entry
         animation slides the pill seed down into so it visually starts from
         BEHIND the taskbar (the window's lower portion overlaps the taskbar). -->
    <Grid x:Name="WindowRoot" Background="Transparent">

        <!-- All visible glass elements live in this 300×66 container at the top
             of WindowRoot. The animated WindowRoot.Clip (set up in
             OnSourceInitialized) and WindowRoot.RenderTransform handle the
             entry morph + slide; we just need the children to render inside
             the pill rect. -->
        <Grid x:Name="PillContainer" Width="300" Height="66"
              VerticalAlignment="Top" HorizontalAlignment="Left">

        <!-- ===== Liquid Glass full bitmap =====
             ImageBrush is 300x66; the renderer fills it with the pill, the shadow
             halo around the pill, and transparent pixels outside the shadow. Border
             has no CornerRadius because the alpha mask already handles the shape. -->
        <Border x:Name="GlassBackdrop"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <ImageBrush x:Name="GlassBackdropBrush" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <!-- Tint layer for Solid/Subtle modes (NOT used in LiquidGlass — it's transparent). -->
        <Border x:Name="TintLayer" CornerRadius="23" Margin="10"/>

        <!-- ====== Solid-fill bar layer (OsdBarStyle.SolidFill) ======
             v0.6.30: moved UP in the z-order. Used to sit just below ContentRoot,
             which meant the brightness bar's solid fill covered the static glass
             gradients (Specular/SideRefraction/BottomSheen/EdgeRing) AND the
             renderer-produced rim/highlights. Now sits BELOW the static
             gradients and BELOW the new GlassHighlights overlay (added below
             ContentRoot), so the bar colour acts as a backdrop layer and all
             the lighting effects are still visible on top of it.

             Spans the FULL pill width — beginning to end, not just the column
             after the icon. The pill's SetWindowRgn clip handles the rounded
             outer corners, so the fills themselves are dead-rectangular: the
             leading edge (where each fill meets the centre) is a straight
             vertical line and the outer edge is whatever the pill clips it to.

             Brightness 0 corresponds to the GEOMETRIC centre of the pill —
             neg fill grows leftward (covering the icon area), pos fill grows
             rightward — same model Apple uses for its brightness bar. -->
        <Grid x:Name="SolidFillRoot" Margin="10" Visibility="Collapsed"
              IsHitTestVisible="False">
            <!-- Brightness: split into two halves so the fill grows outward
                 from the geometric centre. Fill widths are driven from
                 UpdateBrightnessBar(). -->
            <Grid x:Name="SolidFillBrightness">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- v0.6.19: same 0..100 grow-from-left logic as the thin bar.
                     SolidFillNeg is the dim-shade half, SolidFillPos is the accent
                     half. Both anchored Left, growing rightward into their column. -->
                <Border Grid.Column="0" x:Name="SolidFillNeg"
                        HorizontalAlignment="Left" Width="0"
                        Background="#FFE5B675"/>
                <Border Grid.Column="1" x:Name="SolidFillPos"
                        HorizontalAlignment="Left" Width="0"
                        Background="#FFFFFFFF"/>
            </Grid>
            <!-- Warmth: single fill that grows from the left edge of the pill
                 toward the right as kelvin increases. Uses the same warmth
                 gradient brush the small bar does. -->
            <Border x:Name="SolidFillWarmthBar"
                    HorizontalAlignment="Left" Width="0"
                    Visibility="Collapsed">
                <Border.Background>
                    <LinearGradientBrush x:Name="SolidFillWarmthGradient"
                                         StartPoint="0,0" EndPoint="1,0">
                        <GradientStop x:Name="SolidFillWarmthStartStop" Offset="0" Color="#FFFF5A00"/>
                        <GradientStop x:Name="SolidFillWarmthEndStop"   Offset="1" Color="#FFFFF9FB"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <!-- ====== Liquid Glass overlay stack ======
             We can't access the DWM-blurred backdrop pixels for a real refraction
             shader, so we simulate the visual cues a glass surface produces:
               • Top specular  — bright reflection at the top edge ("crown of glass")
               • Side refraction gradient — light bends at the left edge, darkens at right
               • Bottom sheen — faint catch-light at the bottom rim
               • Inner glow — a soft white wash near the top suggesting volume
               • Edge ring — a thin bright outline (the rim of refraction)
             All hidden in Solid/Subtle modes. -->

        <!-- Top specular: strong white highlight on top ~25%, fades to nothing -->
        <Border x:Name="GlassSpecular"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.00" Color="#80FFFFFF"/>
                    <GradientStop Offset="0.06" Color="#50FFFFFF"/>
                    <GradientStop Offset="0.18" Color="#1AFFFFFF"/>
                    <GradientStop Offset="0.40" Color="#00FFFFFF"/>
                    <GradientStop Offset="1.00" Color="#00FFFFFF"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Side refraction: slight brightening on the left edge, very subtle dark on the right -->
        <Border x:Name="GlassSideRefraction"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Offset="0.00" Color="#28FFFFFF"/>
                    <GradientStop Offset="0.04" Color="#10FFFFFF"/>
                    <GradientStop Offset="0.50" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.96" Color="#00000000"/>
                    <GradientStop Offset="1.00" Color="#15000000"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Bottom sheen: subtle catch-light at the very bottom edge -->
        <Border x:Name="GlassBottomSheen"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.00" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.78" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.92" Color="#1AFFFFFF"/>
                    <GradientStop Offset="1.00" Color="#33FFFFFF"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Edge ring (Solid/Subtle only — LiquidGlass uses renderer Fresnel). -->
        <Border x:Name="EdgeRing"
                CornerRadius="23"
                Margin="10"
                BorderBrush="#1FFFFFFF"
                BorderThickness="1"
                IsHitTestVisible="False"/>

        <!-- ===== Liquid Glass HIGHLIGHTS overlay =====
             v0.6.30: rim + specular layer split out from GlassBackdrop. Sits
             ABOVE SolidFillRoot, the static glass gradients, and the EdgeRing —
             so the brightness bar fill never covers the rim line or the
             specular highlights. Same Stretch=Fill / 300×66 footprint as
             GlassBackdrop. Hidden in Solid/Subtle modes. -->
        <Border x:Name="GlassHighlights"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <ImageBrush x:Name="GlassHighlightsBrush" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <!-- Content: icon + bar. No DropShadowEffect — it was casting a faint
             rectangular halo around the bar/icon shapes that read as "weird shadow
             behind the pill". Renderer's vibrancy step keeps icons readable on
             bright backgrounds without an explicit shadow. -->
        <Grid Margin="22,0,24,0" x:Name="ContentRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="22" Height="22"
                  VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="&#xE706;"/>
                <Path x:Name="CandleIcon"
                      Visibility="Collapsed"
                      Fill="#FFFFFFFF"
                      Stretch="Uniform"
                      Width="22" Height="22"
                      VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Path.Data>
                        <GeometryGroup FillRule="Nonzero">
                            <PathGeometry>
                                <PathFigure StartPoint="7,0.5" IsClosed="True">
                                    <BezierSegment Point1="10.5,2.5" Point2="10.5,5.5" Point3="7,6.5"/>
                                    <BezierSegment Point1="3.5,5.5" Point2="3.5,2.5" Point3="7,0.5"/>
                                </PathFigure>
                            </PathGeometry>
                            <RectangleGeometry Rect="6.55,6.5,0.9,2"/>
                            <RectangleGeometry Rect="4.75,8.5,4.5,9" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </Path.Data>
                </Path>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                  Height="4" x:Name="BarRoot" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="BarSlideTransform" Y="0"/>
                </Grid.RenderTransform>

                <Grid x:Name="BrightnessBar">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TrackLeft"  Grid.Column="0" CornerRadius="2,0,0,2" Background="#33FFFFFF"/>
                    <!-- v0.6.19: bar grows from LEFT edge as a 0..100 indicator. The two
                         fills now sit side by side (both anchored Left): FillLeft is the
                         "below 50" / sub-Windows-native dim half (darker shade), FillRight
                         is the "above 50" / Windows-native half (accent). The split at the
                         50 mark gives a hard colour transition that signals "you're below
                         the OS minimum" without animating per-step. -->
                    <Border Grid.Column="0" x:Name="FillLeft"
                            HorizontalAlignment="Left" CornerRadius="2,0,0,2"
                            Background="#FFE5B675" Width="0"/>
                    <Border x:Name="TrackRight" Grid.Column="1" CornerRadius="0,2,2,0" Background="#33FFFFFF"/>
                    <Border Grid.Column="1" x:Name="FillRight"
                            HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                            Background="#FFFFFFFF" Width="0"/>
                    <Border x:Name="MidMarker"
                            Grid.ColumnSpan="2"
                            Width="2" Height="14"
                            Background="#B3FFFFFF"
                            CornerRadius="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Grid>

                <Grid x:Name="WarmthBar" Visibility="Collapsed">
                    <Border x:Name="WarmthTrack" CornerRadius="2" Background="#33FFFFFF"/>
                    <Border x:Name="WarmthFill"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Width="0">
                        <Border.Background>
                            <LinearGradientBrush x:Name="WarmthGradient"
                                                 StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="WarmthStartStop" Offset="0" Color="#FFFF5A00"/>
                                <GradientStop x:Name="WarmthEndStop"   Offset="1" Color="#FFFFF9FB"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        </Grid>  <!-- /PillContainer -->
    </Grid>
</Window>
