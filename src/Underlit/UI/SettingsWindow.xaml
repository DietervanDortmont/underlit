<Window x:Class="Underlit.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Underlit.UI"
        Title="Underlit Settings"
        Width="760" Height="600"
        MinWidth="680" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True">

    <Window.Resources>
        <!--
            v0.6.40: visual system overhaul. Apple/iOS-flavoured palette,
            consistent typography rhythm (page title 22 / caption 11 SC /
            row label 13 / value chip 12 SC), pill-shaped scrollbar, iOS-
            style toggle switch, refined slider, themed tooltip.
            All theme-reactive brushes are DynamicResource — populated by
            ApplyTheme() at runtime to follow Windows dark/light only
            (no longer dependent on OSD backdrop choice).
        -->

        <!-- ===== Sidebar ===== -->
        <Style x:Key="SidebarItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="10,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.SelectedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Card / row scaffolding ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="CardCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="Margin" Value="6,18,0,8"/>
            <!-- iOS-style "section header": small caps with a touch of letter spacing. -->
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource App.Divider}"/>
            <Setter Property="Margin" Value="16,0"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="16,0,12,0"/>
        </Style>

        <!-- Inline hint TextBlocks are deprecated in v0.6.40; kept as a
             style so XAML that still uses it doesn't break, but we set
             Visibility=Collapsed by default so leftover hints just don't
             render. The same explanatory text shows up as a tooltip on
             the adjacent control instead, on hover. -->
        <Style x:Key="RowHint" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <!-- ===== Themed tooltip (Apple-style minimal popup) ===== -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource App.CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                MaxWidth="320">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="14"
                                                  ShadowDepth="2" Opacity="0.18"/>
                            </Border.Effect>
                            <!-- v0.6.41: TextBlock.TextWrapping is NOT an
                                 attached property in WPF, so it can't be
                                 set on ContentPresenter (CI build flagged
                                 MC3015). Bind a TextBlock directly to the
                                 tooltip's Content instead. All call sites
                                 pass plain strings, which is the common
                                 tooltip case. -->
                            <TextBlock Text="{TemplateBinding Content}"
                                       TextWrapping="Wrap"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== iOS-style toggle switch =====
             Two layered backgrounds: the off-state track (theme grey, always
             present underneath) plus a green ON overlay whose Opacity
             animates 0..1 on IsChecked. This avoids the v0.6.40 problem
             where the ColorAnimation only had EnterActions, so flipping
             OFF left the track stuck on green. The opacity approach also
             means the brushes don't get globally mutated, which is what
             happens when you ColorAnimate on a DynamicResource brush.
        -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="44" Height="26"
                                CornerRadius="13"
                                Background="{DynamicResource App.ToggleTrackOff}"
                                BorderThickness="0">
                            <Grid>
                                <!-- Green overlay for the ON state. Opacity
                                     animates 0..1 to fade in/out. -->
                                <Border x:Name="OnOverlay"
                                        CornerRadius="13"
                                        Background="#FF34C759"
                                        Opacity="0"/>
                                <Ellipse x:Name="Knob"
                                         Width="22" Height="22"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         Fill="White"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="KnobShift" X="0"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="4"
                                                          ShadowDepth="1" Opacity="0.30"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                             Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="OnOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobShift"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="OnOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default every CheckBox to the toggle switch look unless a
             site explicitly opts out. -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource ToggleSwitch}"/>

        <!-- ===== Apple-style slider ===== -->
        <Style x:Key="AppleSliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="6"
                                                      ShadowDepth="1" Opacity="0.28"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse x:Name="Halo" Fill="{DynamicResource App.Accent}"
                                     Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Halo" Property="Opacity" Value="0.10"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Halo" Property="Opacity" Value="0.18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppleSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Accent}"/>
            <Setter Property="Background" Value="{DynamicResource App.TrackBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="22">
                            <Border Height="4" CornerRadius="2"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}"/>
                            <Track x:Name="PART_Track" Height="22" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <!-- The "decrease" side of the track is the
                                                     filled portion (left of thumb); paint it
                                                     with the slider's accent foreground. -->
                                                <Border Height="4" CornerRadius="2"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding Foreground,
                                                                     RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AppleSliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Themed text input ===== -->
        <Style x:Key="AppleTextBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="{DynamicResource App.InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Refined dropdown (ComboBox) ===== -->
        <Style x:Key="AppleComboBox" TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Padding" Value="12,7,10,7"/>
            <Setter Property="Background" Value="{DynamicResource App.InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                CornerRadius="8"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Background>
                                    <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </ToggleButton.Background>
                                <ToggleButton.BorderBrush>
                                    <Binding Path="BorderBrush" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </ToggleButton.BorderBrush>
                                <ToggleButton.BorderThickness>
                                    <Binding Path="BorderThickness" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </ToggleButton.BorderThickness>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Path x:Name="Arrow"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Width="9" Height="6"
                                  Stretch="Fill"
                                  Fill="{DynamicResource App.TextSecondary}"
                                  Data="M 0 0 L 4.5 6 L 9 0 Z"/>
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,4,0,8"
                                        CornerRadius="10"
                                        Background="{DynamicResource App.CardBg}"
                                        BorderBrush="{DynamicResource App.CardBorder}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="20"
                                                          ShadowDepth="3" Opacity="0.22"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource App.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.SelectedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default ComboBox to the Apple style without forcing every site
             to opt in via Style attribute. -->
        <Style TargetType="ComboBox" BasedOn="{StaticResource AppleComboBox}"/>

        <!-- ===== Pill scrollbar ===== -->
        <Style x:Key="PillScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3"
                                Background="{DynamicResource App.TextSecondary}"
                                Opacity="0.42"
                                Margin="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Width="6"
                                   HorizontalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PillScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="MinHeight" Value="10"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ValueChip" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <!-- Wide enough that "+200 K" / "1500 K" fit without clipping. -->
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0,16,0"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <!-- Default Slider style — every Slider in the app picks up the
             AppleSlider template (thin track, glass thumb, accent fill on
             the left). The previous v0.6.40 keyed AppleSlider with no
             default meant that liquid-glass tuning sliders (which weren't
             explicitly opted in) kept the chunky default WPF look. -->
        <Style TargetType="Slider" BasedOn="{StaticResource AppleSlider}"/>

        <!-- ===== Icon button (transparent, scale-bounce on hover) =====
             Used for the profile rename / clone / delete row. No visible
             box; hover scales the icon up about 12% with a quick bouncy
             cubic-out so it feels lively without grabbing attention. -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.16" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.16" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Pill action button =====
             v0.6.45: shorter (5 px vertical padding), high-contrast
             background (App.ButtonBg = dark in light mode, light in dark
             mode), no border, hover = scale-up bounce only (no colour
             shift / no border highlight). Reads as a real button against
             the surrounding card without the chunky WPF default chrome. -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource App.ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.ButtonFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.04" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.04" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.96" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.96" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource App.WindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource App.SidebarBg}" Padding="0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,4,16,16" Orientation="Horizontal">
                    <Image x:Name="AppLogo" Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="Underlit"
                               FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource App.TextPrimary}"/>
                </StackPanel>
                <ListBox x:Name="NavList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectedIndex="0"
                         ItemContainerStyle="{StaticResource SidebarItem}">
                    <ListBoxItem Content="General"/>
                    <ListBoxItem Content="Hotkeys"/>
                    <ListBoxItem Content="Schedule"/>
                    <ListBoxItem Content="Lights"/>
                    <ListBoxItem Content="Monitors"/>
                    <ListBoxItem Content="Exclusions"/>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <ScrollViewer x:Name="MainContentScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="OnSmoothScroll"
                          Padding="32,28,32,32">
                <Grid>
                    <!-- GENERAL -->
                    <StackPanel x:Name="PageGeneral">
                        <TextBlock Style="{StaticResource PageTitle}" Text="General"/>

                        <TextBlock Style="{StaticResource CardCaption}" Text="BEHAVIOR"/>
