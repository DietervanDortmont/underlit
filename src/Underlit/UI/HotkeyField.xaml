<UserControl x:Class="Underlit.UI.HotkeyField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI Variable, Segoe UI"
             FontSize="13"
             FocusVisualStyle="{x:Null}"
             Cursor="Hand"
             Focusable="True"
             KeyboardNavigation.TabNavigation="Once">
    <!--
        Apple-style listen-to-bind hotkey field.

        Three visible states:
          • Idle      — shows the current binding ("Ctrl+Alt+Up"), faint border.
          • Listening — accent ring, placeholder "Press a combination…", small
                        keyboard glyph on the right.
          • Empty     — shows "(none — click to set)" in muted grey.

        State transitions are driven from code-behind (HotkeyField.xaml.cs).
        We render them via two layered Borders: the OUTER one carries the accent
        ring (animated colour), the INNER carries the field background. That way
        we can fade the ring in/out without disturbing the field itself.
    -->
    <Grid x:Name="Root">
        <!-- Outer accent ring — only visible during listening. Always present in the
             tree so the opacity animation has a target. The colour follows the
             app's theme-resolved accent so it tracks the user's Windows accent
             (or their custom override). -->
        <Border x:Name="AccentRing"
                CornerRadius="9"
                Margin="-2"
                BorderThickness="2"
                BorderBrush="{DynamicResource App.Accent}"
                Opacity="0"
                IsHitTestVisible="False"/>

        <!-- The actual field. Faint border in idle, becomes invisible during
             listening (the accent ring takes over the visual). -->
        <Border x:Name="FieldBorder"
                CornerRadius="7"
                BorderThickness="1"
                BorderBrush="{DynamicResource App.CardBorder}"
                Background="{DynamicResource App.CardBg}"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Value text (idle) and listening prompt share this slot;
                     code-behind toggles which is visible. -->
                <TextBlock x:Name="ValueText"
                           Foreground="{DynamicResource App.TextPrimary}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="HintText"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource App.TextSecondary}"
                           VerticalAlignment="Center"
                           Text="Press a combination…"
                           FontStyle="Italic"/>

                <!-- Right-side affordance: subtle ⌨ glyph during listening,
                     small "✕" clear button when there's a binding to clear. -->
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock x:Name="KbdGlyph"
                               Visibility="Collapsed"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="{DynamicResource App.TextSecondary}"
                               Text="&#xE765;"/>
                    <Button x:Name="ClearButton"
                            Visibility="Collapsed"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            Cursor="Hand"
                            ToolTip="Clear binding"
                            Focusable="False">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="11"
                                   Foreground="{DynamicResource App.TextSecondary}"
                                   Text="&#xE711;"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Inline warning balloon — shown briefly when the user tries to bind
             a single key with no modifier. Auto-fades after ~2s. -->
        <Border x:Name="WarningBalloon"
                Visibility="Collapsed"
                Margin="0,42,0,0"
                CornerRadius="6"
                Padding="8,4"
                Background="#22DC2626"
                BorderBrush="#66DC2626"
                BorderThickness="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                IsHitTestVisible="False">
            <TextBlock x:Name="WarningText"
                       FontSize="11"
                       Foreground="#FFE89090"/>
        </Border>
    </Grid>
</UserControl>
