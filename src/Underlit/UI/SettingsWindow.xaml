                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Corner radius"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassCornerRadius"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassCornerRadius, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Bevel width"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassBevelWidth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassBevelWidth, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Bevel depth"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassBevelDepth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassBevelDepth, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim brightness"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimBrightness"
                                            Minimum="0" Maximum="300" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimBrightness, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim width"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimWidth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimWidth, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim secondary"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimSecondary"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimSecondary, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- HOTKEYS -->
                    <StackPanel x:Name="PageHotkeys" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Hotkeys"/>
                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,16"
                                   Text="Click a field and press the key combination you want. Esc cancels, Backspace clears. Bindings need at least one modifier (Ctrl, Alt, Shift, or Win) so a single key isn't hijacked system-wide."/>

                        <TextBlock Style="{StaticResource CardCaption}" Text="BRIGHTNESS"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness down"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness up"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="WARMTH"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmer"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkWrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Cooler"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkWrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="PHILIPS HUE"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Hue brightness down"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkHueBrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Hue brightness up"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkHueBrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Hue warmer"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Subtracts from the warmth offset (lights drift toward warmer)."/>
                                    </StackPanel>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkHueWrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Hue cooler"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkHueWrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="OTHER"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Boost"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Toggle: once jumps to full, again restores."/>
                                    </StackPanel>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBoost" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Toggle Underlit on/off"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkToggle" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- SCHEDULE -->
                    <StackPanel x:Name="PageSchedule" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Schedule"/>

                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,12"
                                   Text="On: Underlit follows the day to night curve below. Your screen warms in the evening and resets to neutral in the morning, applied immediately on launch. Off: you control warmth manually with hotkeys, and whatever you set persists until you change it."/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Warmth follows a schedule"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="Override automatically every 30 seconds while running."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" x:Name="ChkScheduleEnabled" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Schedule curve cards — dimmed/disabled when the toggle above is off so the
                             user gets a clear signal that they're inert in manual mode. IsEnabled
                             binding handles the disable state; Opacity binding handles the visual cue. -->
                        <StackPanel x:Name="SchedulePanelCurve"
                                    IsEnabled="{Binding ElementName=ChkScheduleEnabled, Path=IsChecked}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ChkScheduleEnabled, Path=IsChecked}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                        <!-- ====== PROFILE PICKER ======
                             Apple-style: a thin pill row with the active profile in a dropdown,
                             flanked by + (clone current → new profile) and − (delete; disabled
                             on the built-in "Recommended" profile). The profile drives the
                             Bedtime / WakeTime / Night warmth values below. Switching profiles
                             instantly retargets the curve. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="PROFILE"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid VerticalAlignment="Center" Margin="14,0,8,0">
                                        <ComboBox x:Name="CboProfile"
                                                  VerticalAlignment="Center"
                                                  MinWidth="200"
                                                  IsEditable="False"/>
                                        <TextBox x:Name="TxtProfileRename"
                                                 Style="{StaticResource AppleTextBox}"
                                                 Visibility="Collapsed"
                                                 Margin="0"
                                                 HorizontalAlignment="Stretch"
                                                 TextAlignment="Left"
                                                 HorizontalContentAlignment="Left"/>
                                    </Grid>
                                    <Button Grid.Column="1" x:Name="BtnRenameProfile"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Rename this profile">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE70F;"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnAddProfile"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Clone current profile to a new one">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE710;"/>
                                    </Button>
                                    <Button Grid.Column="3" x:Name="BtnRemoveProfile"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Delete this profile">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE738;"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ====== DAY/NIGHT CURVE (read-only graph, derived from Bedtime + WakeTime) ======
                             Drag-to-edit landed in v0.6.23+ as a planned follow-up; for now the
                             curve is auto-derived from the active profile's two anchor times via
                             the circadian-physiology model. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="DAY/NIGHT CURVE"/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <StackPanel>
                                <Grid Margin="14,12,14,8" Height="120">
                                    <Canvas x:Name="ScheduleGraph" ClipToBounds="True"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ====== TIMES — four independently editable anchors ======
                             Each of the four schedule anchors (evening-ramp start, bedtime,
                             morning-ramp start, wake) is an independent time. Editing any
                             one of them does NOT shift the others — that includes dragging
                             the corresponding point on the graph. To keep the bedtime ramp
                             at a particular length you adjust BOTH "Evening ramp starts"
                             and "Bedtime", same for the morning side. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="TIMES"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Evening ramp starts"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="When the screen begins shifting from neutral toward bedtime warmth."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtBedtimeStart" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Bedtime"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="When deep warmth is fully reached. Independent of the ramp-start time above."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtBedtime" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Morning ramp starts"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="When the screen begins shifting from bedtime warmth back toward neutral."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtWakeupStart" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Wake time"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="When neutral is fully reached. Independent of the ramp-start time above."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtWakeTime" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="NIGHT WARMTH"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmth at night (K)"/>
                                    <Slider Grid.Column="1" x:Name="SldNightWarmth" Style="{StaticResource AppleSlider}"
                                            Minimum="1500" Maximum="6500" TickFrequency="100" IsSnapToTickEnabled="True"/>
                                    <!-- Live preview: shows the actual screen tint produced at the
                                         selected kelvin, updated as the user drags the slider. -->
                                    <Border Grid.Column="2" x:Name="NightWarmthPreview"
                                            Margin="8,0,8,0" Width="32" Height="22" CornerRadius="4"
                                            BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"
                                            ToolTip="Preview of the screen tint at this kelvin"/>
                                    <TextBlock Grid.Column="3" Style="{StaticResource ValueChip}" x:Name="LblNightWarmth"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        </StackPanel>  <!-- /SchedulePanelCurve -->
                    </StackPanel>

                    <!-- LIGHTS — Philips Hue integration -->
                    <StackPanel x:Name="PageLights" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Lights"/>

                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,12"
                                   Text="Connect a Philips Hue Bridge so your room lighting can follow Underlit's circadian schedule. Bulbs you select here will warm down with the screen on the bedtime ramp and return to neutral on the morning ramp."/>

                        <!-- DISCONNECTED: discovery + manual IP entry -->
                        <StackPanel x:Name="HuePanelDisconnected" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource CardCaption}" Text="FIND YOUR BRIDGE"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource RowHint}" Margin="14,12,14,8"
                                               Text="Underlit can locate your bridge via Philips' discovery service, or you can enter its IP directly if you already know it."/>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Auto-discover bridges on your network"/>
                                        <Button Grid.Column="1" x:Name="BtnHueDiscover" Margin="0,0,14,0"
                                                Style="{StaticResource PillButton}" Content="Discover"/>
                                    </Grid>
                                    <Border Style="{StaticResource RowDivider}"/>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Or enter bridge IP manually"/>
                                        <TextBox Grid.Column="1" x:Name="TxtHueManualIp"
                                                 Width="160" Margin="0,0,8,0"
                                                 Padding="6,4"
                                                 ToolTip="e.g. 192.168.1.42"/>
                                        <Button Grid.Column="2" x:Name="BtnHueConnectManual" Margin="0,0,14,0"
                                                Style="{StaticResource PillButton}" Content="Use this"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="HueDiscoveredCard" Style="{StaticResource Card}" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource RowHint}" Margin="14,12,14,8"
                                               Text="Bridges found on your network:"/>
                                    <ListBox x:Name="LstHueBridges" Margin="14,0,14,12"
                                             MaxHeight="120" BorderThickness="1"
                                             BorderBrush="{DynamicResource App.CardBorder}"
                                             Background="Transparent"/>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="LblHueDiscoverStatus"
                                       Style="{StaticResource RowHint}"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- PAIRING: link-button countdown -->
                        <StackPanel x:Name="HuePanelPairing" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource CardCaption}" Text="PAIR WITH BRIDGE"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel Margin="14,14,14,14">
                                    <TextBlock Style="{StaticResource RowLabel}" Margin="0,0,0,8"
                                               Text="Press the link button on the top of your Hue Bridge"/>
                                    <TextBlock Style="{StaticResource RowHint}"
                                               Text="It's the round button on the bridge's lid. After you press it you have ~30 seconds to click Pair below."/>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LblHuePairingStatus"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource App.TextSecondary}"
                                                   FontSize="11"/>
                                        <Button Grid.Column="1" x:Name="BtnHuePairCancel"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource PillButton}"
                                                Content="Back"/>
                                        <Button Grid.Column="2" x:Name="BtnHuePair"
                                                Style="{StaticResource PillButton}"
                                                Background="{DynamicResource App.Accent}"
                                                BorderThickness="0"
                                                Foreground="White"
                                                Content="Pair"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- CONNECTED: group selection + colour range + actions -->
                        <StackPanel x:Name="HuePanelConnected" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource CardCaption}" Text="BRIDGE"/>
                            <Border Style="{StaticResource Card}">
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" x:Name="LblHueBridgeIp" Text="Connected to bridge"/>
                                        <TextBlock Style="{StaticResource RowHint}" x:Name="LblHueBridgeStatus" Text="Reachable"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnHueUnpair" Margin="0,0,14,0"
                                            Style="{StaticResource PillButton}"
                                            Content="Unpair"/>
                                </Grid>
                            </Border>

                            <TextBlock Style="{StaticResource CardCaption}" Text="GROUPS"/>
                            <Border Style="{StaticResource Card}" Padding="0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource RowHint}" Margin="14,12,14,8"
                                               Text="Tick any rooms / zones / groups Underlit should follow. Lights you don't tick are left alone."/>
                                    <ItemsControl x:Name="HueGroupsList" Margin="14,4,14,12">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- v0.6.42: switch on the right, label on the
                                                     left, mirroring the rest of the toggle rows. -->
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource App.TextPrimary}"
                                                               FontSize="13"/>
                                                    <CheckBox Grid.Column="1"
                                                              Style="{StaticResource ToggleSwitch}"
                                                              Margin="0"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Style="{StaticResource RowDivider}"/>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Refresh group list / test selection"/>
                                        <Button Grid.Column="1" x:Name="BtnHueRefreshGroups"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource PillButton}" Content="Refresh"/>
                                        <Button Grid.Column="2" x:Name="BtnHueTest"
                                                Margin="0,0,14,0"
                                                Style="{StaticResource PillButton}" Content="Test"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Style="{StaticResource CardCaption}" Text="COLOUR RANGE"/>
                            <Border Style="{StaticResource Card}">
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="How lights match the warmth schedule"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="Circadian: native colour temperature (subtle, recommended). White → red: full RGB drift toward deep red in the evening (dramatic). Warm white only: clamped 5000–2700 K range, gentlest."/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="CboHueColorRange"
                                              Margin="0,0,14,0" MinWidth="160" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Circadian (recommended)"/>
                                        <ComboBoxItem Content="Custom gradient"/>
                                        <ComboBoxItem Content="Warm white only"/>
                                    </ComboBox>
                                </Grid>
                                <!-- v0.6.45: gradient endpoints, only visible when
                                     "Custom gradient" is selected. Click a swatch to pick. -->
                                <Border x:Name="HueGradientPanel"
                                        Style="{StaticResource RowDivider}"
                                        Visibility="Collapsed"/>
                                <Grid x:Name="HueGradientRow"
                                      Style="{StaticResource Row}"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Gradient endpoints"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="The lights smoothly transition from the cool colour at neutral daytime warmth (6500 K) to the warm colour at the deepest evening warmth (1500 K). Click a swatch to change it."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnHueGradientCool"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Cool end (daytime). Default: white.">
                                        <Border x:Name="HueGradientCoolSwatch"
                                                Width="36" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnHueGradientWarm"
                                            Margin="0,0,14,0"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Warm end (deep evening). Default: deep red.">
                                        <Border x:Name="HueGradientWarmSwatch"
                                                Width="36" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Style="{StaticResource CardCaption}" Text="ADJUSTMENT"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource RowLabel}" Text="Brightness"/>
                                            <TextBlock Style="{StaticResource RowHint}"
                                                       Text="How bright the selected groups should be. Independent of screen brightness."/>
                                        </StackPanel>
                                        <Slider Grid.Column="1" x:Name="SldHueBrightness" Style="{StaticResource AppleSlider}"
                                                Minimum="0" Maximum="100" TickFrequency="5"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblHueBrightness"/>
                                    </Grid>
                                    <Border Style="{StaticResource RowDivider}"/>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource RowLabel}" Text="Warmth offset (K)"/>
                                            <TextBlock Style="{StaticResource RowHint}"
                                                       Text="Added to the screen's warmth. Negative = warmer than the screen, positive = cooler."/>
                                        </StackPanel>
                                        <Slider Grid.Column="1" x:Name="SldHueWarmthOffset" Style="{StaticResource AppleSlider}"
                                                Minimum="-3000" Maximum="3000" TickFrequency="100"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblHueWarmthOffset"/>
                                    </Grid>
                                    <Border Style="{StaticResource RowDivider}"/>
                                    <Grid Style="{StaticResource Row}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource RowLabel}" Text="Ignore screen warmth boost"/>
                                            <TextBlock Style="{StaticResource RowHint}"
                                                       Text="When you boost the screen to neutral white temporarily (focus mode), don't blast Hue lights to white too. Recommended on."/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" x:Name="ChkHueIgnoreBoost" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- MONITORS -->
                    <StackPanel x:Name="PageMonitors" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Monitors"/>
                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,16"
                                   Text="Per-monitor offsets are added to the global brightness and warmth. Useful for a main monitor that's physically much brighter than a secondary one."/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <ListView x:Name="LstMonitors" Background="Transparent" BorderThickness="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="14,10"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="Bd"
                                                            CornerRadius="6"
                                                            Margin="6,2"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <GridViewRowPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.HoverBg}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.SelectedBg}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Padding" Value="14,8"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Header="Display" Width="220" DisplayMemberBinding="{Binding DeviceName}"/>
                                        <GridViewColumn Header="Brightness" Width="120" DisplayMemberBinding="{Binding BrightnessOffset, StringFormat={}{0:+0;-0;0}}"/>
                                        <GridViewColumn Header="Warmth (K)" Width="120" DisplayMemberBinding="{Binding WarmthOffset, StringFormat={}{0:+0;-0;0} K}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                        <TextBlock Style="{StaticResource CardCaption}" Text="ADJUST SELECTED MONITOR"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness offset"/>
                                    <Slider Grid.Column="1" x:Name="SldMonBrOffset"
                                            Minimum="-50" Maximum="50"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblMonBr"
                                               Cursor="SizeWE"
                                               ToolTip="Drag horizontally to adjust. Double-click to type a value."/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmth offset (K)"/>
                                    <Slider Grid.Column="1" x:Name="SldMonWrOffset"
                                            Minimum="-2000" Maximum="0"
                                            TickFrequency="50"
                                            IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblMonWr"
                                               Cursor="SizeWE"
                                               ToolTip="Drag horizontally to adjust. Double-click to type a value."/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Reset all per-monitor offsets to zero"/>
                                    <Button Grid.Column="1" x:Name="BtnResetMonitors"
                                            Margin="0,0,16,0"
                                            Style="{StaticResource PillButton}"
                                            Content="Reset all"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- EXCLUSIONS -->
                    <StackPanel x:Name="PageExclusions" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Exclusions"/>
                        <TextBlock Margin="0,0,0,16"
                                   Foreground="{DynamicResource App.TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Underlit pauses its dimming whenever any app on this list is in the foreground. Toggle a running app from the list, or add a custom name below."/>

                        <!-- Currently-running apps with toggle switches. The list
                             refreshes when the page is shown; the user can also
                             pull the latest with the Refresh button at the bottom. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="RUNNING APPS"/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <StackPanel>
                                <ItemsControl x:Name="LstRunningApps" Margin="6,8,6,4"
                                              MaxHeight="320">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          PreviewMouseWheel="OnSmoothScroll">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource App.TextPrimary}"
                                                               FontSize="13"/>
                                                    <TextBlock Text="{Binding ProcessName}"
                                                               Foreground="{DynamicResource App.TextSecondary}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          Margin="0,0,4,0"
                                                          IsChecked="{Binding IsExcluded, Mode=TwoWay}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}"
                                               Text="Re-scan running apps"/>
                                    <Button Grid.Column="1" x:Name="BtnRefreshRunningApps"
                                            Margin="0,0,16,0"
                                            Style="{StaticResource PillButton}"
                                            Content="Refresh"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Custom names: power-user textbox for apps the user
                             wants to exclude even when they aren't currently
                             running, or that don't appear in the list (services,
                             hidden processes, etc.). One name per line, no
                             extension. We auto-resolve them at runtime by
                             matching against the foreground process's name. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="CUSTOM"/>
                        <Border Style="{StaticResource Card}" Padding="4">
                            <StackPanel>
                                <TextBox x:Name="TxtExclusions"
                                         Style="{StaticResource AppleTextBox}"
                                         MinHeight="120"
                                         HorizontalAlignment="Stretch"
                                         Margin="0"
                                         TextAlignment="Left"
                                         HorizontalContentAlignment="Stretch"
                                         FontFamily="Cascadia Mono, Consolas"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         ToolTip="One name per line. Leave off the .exe. We match against the foreground app's process name."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
