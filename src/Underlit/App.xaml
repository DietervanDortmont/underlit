<Application x:Class="Underlit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Reusable colors/styles for OSD and settings window -->
            <SolidColorBrush x:Key="Osd.Background" Color="#F21E1E1E"/>
            <SolidColorBrush x:Key="Osd.Foreground" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="Osd.Accent"     Color="#FF60A5FA"/>
            <SolidColorBrush x:Key="Osd.Track"      Color="#FF3A3A3A"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
