<Window x:Class="Underlit.UI.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Width="300"
        Height="66"
        Opacity="0"
        WindowStartupLocation="Manual"
        Title="Underlit">
    <!--
        Layout strategy (v0.3 rewrite):
          • Window is 300x66 with AllowsTransparency=true. The visible pill is 280x46
            inside, with a 10px margin all around so we can render a soft shadow halo
            into the captured-image's alpha channel without it being clipped at the
            window boundary. Apple's pills ride on a soft elevation shadow — DWM's
            window shadow doesn't behave well with layered windows and only works
            with rectangular outlines, so we do it ourselves.
          • CornerRadius=23 on every visible layer = full pill (height/2). DWM's
            8px rounding doesn't apply when AllowsTransparency=true; the corners come
            from our own renderer's alpha mask.
          • No DWM acrylic in this mode — the renderer draws the entire glass body
            including refraction, Phong specular, Fresnel rim, and the soft shadow.
    -->

    <Grid x:Name="WindowRoot">

        <!-- ===== Liquid Glass full bitmap =====
             ImageBrush is 300x66; the renderer fills it with the pill, the shadow
             halo around the pill, and transparent pixels outside the shadow. Border
             has no CornerRadius because the alpha mask already handles the shape. -->
        <Border x:Name="GlassBackdrop"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <ImageBrush x:Name="GlassBackdropBrush" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <!-- Tint layer for Solid/Subtle modes (NOT used in LiquidGlass — it's transparent). -->
        <Border x:Name="TintLayer" CornerRadius="23" Margin="10"/>

        <!-- ====== Liquid Glass overlay stack ======
             We can't access the DWM-blurred backdrop pixels for a real refraction
             shader, so we simulate the visual cues a glass surface produces:
               • Top specular  — bright reflection at the top edge ("crown of glass")
               • Side refraction gradient — light bends at the left edge, darkens at right
               • Bottom sheen — faint catch-light at the bottom rim
               • Inner glow — a soft white wash near the top suggesting volume
               • Edge ring — a thin bright outline (the rim of refraction)
             All hidden in Solid/Subtle modes. -->

        <!-- Top specular: strong white highlight on top ~25%, fades to nothing -->
        <Border x:Name="GlassSpecular"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.00" Color="#80FFFFFF"/>
                    <GradientStop Offset="0.06" Color="#50FFFFFF"/>
                    <GradientStop Offset="0.18" Color="#1AFFFFFF"/>
                    <GradientStop Offset="0.40" Color="#00FFFFFF"/>
                    <GradientStop Offset="1.00" Color="#00FFFFFF"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Side refraction: slight brightening on the left edge, very subtle dark on the right -->
        <Border x:Name="GlassSideRefraction"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Offset="0.00" Color="#28FFFFFF"/>
                    <GradientStop Offset="0.04" Color="#10FFFFFF"/>
                    <GradientStop Offset="0.50" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.96" Color="#00000000"/>
                    <GradientStop Offset="1.00" Color="#15000000"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Bottom sheen: subtle catch-light at the very bottom edge -->
        <Border x:Name="GlassBottomSheen"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.00" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.78" Color="#00FFFFFF"/>
                    <GradientStop Offset="0.92" Color="#1AFFFFFF"/>
                    <GradientStop Offset="1.00" Color="#33FFFFFF"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Edge ring (Solid/Subtle only — LiquidGlass uses renderer Fresnel). -->
        <Border x:Name="EdgeRing"
                CornerRadius="23"
                Margin="10"
                BorderBrush="#1FFFFFFF"
                BorderThickness="1"
                IsHitTestVisible="False"/>

        <!-- Content: icon + bar. No DropShadowEffect — it was casting a faint
             rectangular halo around the bar/icon shapes that read as "weird shadow
             behind the pill". Renderer's vibrancy step keeps icons readable on
             bright backgrounds without an explicit shadow. -->
        <Grid Margin="22,0,24,0" x:Name="ContentRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="22" Height="22"
                  VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="&#xE706;"/>
                <Path x:Name="CandleIcon"
                      Visibility="Collapsed"
                      Fill="#FFFFFFFF"
                      Stretch="Uniform"
                      Width="22" Height="22"
                      VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Path.Data>
                        <GeometryGroup FillRule="Nonzero">
                            <PathGeometry>
                                <PathFigure StartPoint="7,0.5" IsClosed="True">
                                    <BezierSegment Point1="10.5,2.5" Point2="10.5,5.5" Point3="7,6.5"/>
                                    <BezierSegment Point1="3.5,5.5" Point2="3.5,2.5" Point3="7,0.5"/>
                                </PathFigure>
                            </PathGeometry>
                            <RectangleGeometry Rect="6.55,6.5,0.9,2"/>
                            <RectangleGeometry Rect="4.75,8.5,4.5,9" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </Path.Data>
                </Path>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                  Height="4" x:Name="BarRoot" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="BarSlideTransform" Y="0"/>
                </Grid.RenderTransform>

                <Grid x:Name="BrightnessBar">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TrackLeft"  Grid.Column="0" CornerRadius="2,0,0,2" Background="#33FFFFFF"/>
                    <Border Grid.Column="0" x:Name="FillLeft"
                            HorizontalAlignment="Right" CornerRadius="2,0,0,2"
                            Background="#FFE5B675" Width="0"/>
                    <Border x:Name="TrackRight" Grid.Column="1" CornerRadius="0,2,2,0" Background="#33FFFFFF"/>
                    <Border Grid.Column="1" x:Name="FillRight"
                            HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                            Background="#FFFFFFFF" Width="0"/>
                    <Border x:Name="MidMarker"
                            Grid.ColumnSpan="2"
                            Width="2" Height="14"
                            Background="#B3FFFFFF"
                            CornerRadius="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Grid>

                <Grid x:Name="WarmthBar" Visibility="Collapsed">
                    <Border x:Name="WarmthTrack" CornerRadius="2" Background="#33FFFFFF"/>
                    <Border x:Name="WarmthFill"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Width="0">
                        <Border.Background>
                            <LinearGradientBrush x:Name="WarmthGradient"
                                                 StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="WarmthStartStop" Offset="0" Color="#FFFF5A00"/>
                                <GradientStop x:Name="WarmthEndStop"   Offset="1" Color="#FFFFF9FB"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
