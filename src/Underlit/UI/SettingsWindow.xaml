                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Distance above taskbar"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="How far the OSD pill sits above the taskbar's top edge. Higher values lift the OSD farther from the screen edge."/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" x:Name="SldOsdGap" Style="{StaticResource AppleSlider}"
                                            Minimum="0" Maximum="200" TickFrequency="10"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblOsdGap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- BAR COLOUR — split at the 50 mark: accent above, dim shade below. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="BAR COLOUR"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,8"
                                           Text="The brightness bar runs 0 to 100. The right half (50 to 100) uses your Windows accent, the same range the system slider covers. The left half (0 to 50) shifts to a darker shade as a visual cue that you've pushed brightness below the OS minimum into Underlit's extended-dim range. The transition is a single hard switch at 50, not a per-step gradient."/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Sub-OS-min colour"/>
                                        <TextBlock x:Name="LblHighColorMode" Style="{StaticResource RowHint}"
                                                   Text="Auto: darkened from your accent."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnPickHighColor" Margin="0,0,8,0"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="Pick a custom colour for the sub-OS-min half (0 to 50)">
                                        <Border x:Name="HighColorSwatch"
                                                Width="32" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnResetHighColor" Margin="0,0,14,0"
                                            Style="{StaticResource PillButton}"
                                            Content="Auto"
                                            ToolTip="Reset to auto-derive from accent"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LIQUID GLASS TUNING (active when Backdrop = Liquid Glass) -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="LIQUID GLASS"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,8"
                                           Text="Knobs to dial in the look. Press a hotkey while sliding to preview."/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Live capture"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="On: the glass refracts what's behind it in real time. On Windows 11 22H2 and later this shows a brief yellow capture indicator while the OSD is visible. Off: a single snapshot is taken when the OSD appears and frozen for the duration. No yellow indicator on any Windows version."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" x:Name="ChkGlassLiveCapture" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Tint color"/>
                                    <Button Grid.Column="1" x:Name="BtnPickTint" Margin="0,0,14,0" Padding="6"
                                            Cursor="Hand" Background="Transparent" BorderThickness="0">
                                        <Border x:Name="TintSwatch"
                                                Width="32" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Tint strength"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassTintStrength"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassTintStrength, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Light angle"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassLightAngle"
                                            Minimum="-180" Maximum="180"
                                            VerticalAlignment="Center"
                                            TickFrequency="15" IsSnapToTickEnabled="False"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassLightAngle, Path=Value, StringFormat={}{0:F0}°}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Light intensity"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassLightIntensity"
                                            Minimum="0" Maximum="200" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassLightIntensity, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Refraction"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRefraction"
                                            Minimum="0" Maximum="30" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRefraction, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Depth"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassDepth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassDepth, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Dispersion"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassDispersion"
                                            Minimum="0" Maximum="10" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassDispersion, Path=Value, StringFormat={}{0:F1}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Frost"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassFrost"
