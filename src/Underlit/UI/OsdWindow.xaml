<Window x:Class="Underlit.UI.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Width="280"
        Height="60"
        Opacity="0"
        WindowStartupLocation="Manual"
        Title="Underlit">
    <!--
        Modern OSD layout (Win11 22H2+):
          • Window is exactly the visible flyout's footprint (280x60), so the DWM
            backdrop fills only the menu's area — no "huge frame" of blur around it.
          • AllowsTransparency=False is required for DwmSetWindowAttribute backdrop
            to apply. Rounded corners and the soft shadow are provided by DWM via
            DWMWA_WINDOW_CORNER_PREFERENCE = DWMWCP_ROUND (set in code).
          • No internal slide transform — slide animation moves Window.Top.

        On older Windows that don't support the modern API, code falls back to the
        legacy ACCENT_ENABLE_ACRYLICBLURBEHIND with manual rounded corners.
    -->

    <Grid x:Name="WindowRoot">
        <!-- Tint layer. With Acrylic the DWM backdrop shows through the alpha;
             with None we use an opaque colour. -->
        <Border x:Name="BackgroundBorder"
                CornerRadius="8"
                Background="#80202020"
                BorderBrush="#1FFFFFFF"
                BorderThickness="1"/>

        <!-- LiquidGlass mode shows this top-edge specular highlight overlay. -->
        <Border x:Name="GlassHighlight"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0"  Color="#80FFFFFF"/>
                    <GradientStop Offset="0.45" Color="#10FFFFFF"/>
                    <GradientStop Offset="0.55" Color="#00FFFFFF"/>
                    <GradientStop Offset="1.0"  Color="#00FFFFFF"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="12,0,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="22" Height="22"
                  VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="&#xE706;"/>
                <Path x:Name="CandleIcon"
                      Visibility="Collapsed"
                      Fill="#FFFFFFFF"
                      Stretch="Uniform"
                      Width="22" Height="22"
                      VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Path.Data>
                        <GeometryGroup FillRule="Nonzero">
                            <PathGeometry>
                                <PathFigure StartPoint="7,0.5" IsClosed="True">
                                    <BezierSegment Point1="10.5,2.5" Point2="10.5,5.5" Point3="7,6.5"/>
                                    <BezierSegment Point1="3.5,5.5" Point2="3.5,2.5" Point3="7,0.5"/>
                                </PathFigure>
                            </PathGeometry>
                            <RectangleGeometry Rect="6.55,6.5,0.9,2"/>
                            <RectangleGeometry Rect="4.75,8.5,4.5,9" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </Path.Data>
                </Path>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                  Height="4" x:Name="BarRoot">

                <Grid x:Name="BrightnessBar">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TrackLeft"  Grid.Column="0" CornerRadius="2,0,0,2" Background="#33FFFFFF"/>
                    <Border Grid.Column="0" x:Name="FillLeft"
                            HorizontalAlignment="Right" CornerRadius="2,0,0,2"
                            Background="#FFE5B675" Width="0"/>
                    <Border x:Name="TrackRight" Grid.Column="1" CornerRadius="0,2,2,0" Background="#33FFFFFF"/>
                    <Border Grid.Column="1" x:Name="FillRight"
                            HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                            Background="#FFFFFFFF" Width="0"/>
                    <Border x:Name="MidMarker"
                            Grid.ColumnSpan="2"
                            Width="2" Height="14"
                            Background="#B3FFFFFF"
                            CornerRadius="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Grid>

                <Grid x:Name="WarmthBar" Visibility="Collapsed">
                    <Border x:Name="WarmthTrack" CornerRadius="2" Background="#33FFFFFF"/>
                    <Border x:Name="WarmthFill"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Width="0">
                        <Border.Background>
                            <LinearGradientBrush x:Name="WarmthGradient"
                                                 StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="WarmthStartStop" Offset="0" Color="#FFFF5A00"/>
                                <GradientStop x:Name="WarmthEndStop"   Offset="1" Color="#FFFFF9FB"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
