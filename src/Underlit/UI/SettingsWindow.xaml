<Window x:Class="Underlit.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Underlit.UI"
        Title="Underlit Settings"
        Width="760" Height="600"
        MinWidth="680" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- All theme-reactive brushes are DynamicResource. Values set in code by ApplyTheme(). -->

        <Style x:Key="SidebarItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.SelectedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="CardCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="Margin" Value="4,14,0,6"/>
        </Style>

        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource App.Divider}"/>
            <Setter Property="Margin" Value="14,0"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="14,0,12,0"/>
        </Style>

        <Style x:Key="RowHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="14,0,12,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="40" Height="22"
                                CornerRadius="11"
                                Background="{DynamicResource App.ToggleTrackOff}">
                            <Grid>
                                <Ellipse x:Name="Knob"
                                         Width="16" Height="16"
                                         Margin="3"
                                         HorizontalAlignment="Left"
                                         Fill="White"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource App.Accent}"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppleSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Accent}"/>
            <Setter Property="Background" Value="{DynamicResource App.TrackBg}"/>
        </Style>

        <Style x:Key="AppleTextBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="{DynamicResource App.InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValueChip" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0,14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource App.WindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource App.SidebarBg}" Padding="0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,4,16,16" Orientation="Horizontal">
                    <Image x:Name="AppLogo" Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="Underlit"
                               FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource App.TextPrimary}"/>
                </StackPanel>
                <ListBox x:Name="NavList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectedIndex="0"
                         ItemContainerStyle="{StaticResource SidebarItem}">
                    <ListBoxItem Content="General"/>
                    <ListBoxItem Content="Hotkeys"/>
                    <ListBoxItem Content="Schedule"/>
                    <ListBoxItem Content="Monitors"/>
                    <ListBoxItem Content="Exclusions"/>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="32,28,32,32">
                <Grid>
                    <!-- GENERAL -->
                    <StackPanel x:Name="PageGeneral">
                        <TextBlock Style="{StaticResource PageTitle}" Text="General"/>

                        <TextBlock Style="{StaticResource CardCaption}" Text="BEHAVIOR"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Start with Windows"/>
                                    <CheckBox Grid.Column="1" x:Name="ChkStartWithWindows" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Disable Windows Night Light"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Prevents Windows' built-in warmth from conflicting with Underlit's."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" x:Name="ChkDisableNightLight" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <!-- "Hook Fn brightness keys" toggle removed in v0.6.12 — the underlying
                                     low-level hook was matching the wrong VK codes (volume up + media next
                                     instead of brightness) and was silently stealing those keys. The hook
                                     is now a no-op regardless of this setting. The CheckBox stays in the
                                     visual tree (Collapsed) so existing code-behind references still bind. -->
                                <CheckBox x:Name="ChkHookNativeKeys" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="STEP SIZES"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness per keypress"/>
                                    <Slider Grid.Column="1" x:Name="SldBrightnessStep" Style="{StaticResource AppleSlider}"
                                            Minimum="1" Maximum="20" TickFrequency="1"
                                            IsSnapToTickEnabled="True" SmallChange="1"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblBrightnessStep"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmth per keypress"/>
                                    <Slider Grid.Column="1" x:Name="SldWarmthStep" Style="{StaticResource AppleSlider}"
                                            Minimum="50" Maximum="600" TickFrequency="50"
                                            IsSnapToTickEnabled="True" SmallChange="50"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblWarmthStep"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="ANIMATION"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Software fade duration"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Smooths the overlay fade. Hardware brightness always snaps."/>
                                    </StackPanel>
                                    <Slider Grid.Column="1" x:Name="SldRampDuration" Style="{StaticResource AppleSlider}"
                                            Minimum="0" Maximum="400" TickFrequency="20" IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblRampDuration"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="APPEARANCE"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Follow Windows accent color"/>
                                    <CheckBox Grid.Column="1" x:Name="ChkFollowAccent" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Custom accent color"/>
                                    <Button Grid.Column="1" x:Name="BtnPickAccent" Margin="0,0,14,0" Padding="6"
                                            Cursor="Hand" Background="Transparent" BorderThickness="0">
                                        <Border x:Name="AccentSwatch"
                                                Width="32" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Transparency effects"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Acrylic blur behind the OSD. Auto follows your Windows transparency setting."/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="CboTransparency"
                                              Margin="0,0,14,0" MinWidth="100">
                                        <ComboBoxItem Content="Auto"/>
                                        <ComboBoxItem Content="On"/>
                                        <ComboBoxItem Content="Off"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Backdrop style"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="None = solid tint. Acrylic = live frosted blur. Liquid Glass adds an Apple-style highlight on top of acrylic."/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="CboBackdrop"
                                              Margin="0,0,14,0" MinWidth="120">
                                        <ComboBoxItem Content="Solid"/>
                                        <ComboBoxItem Content="Subtle"/>
                                        <ComboBoxItem Content="Liquid Glass"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Bar style"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Bar = thin slider with a partial fill (current default). Solid fill = the bar column fills with a tall pill-shaped block whose width tracks the level. Applies to both brightness and warmth."/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="CboBarStyle"
                                              Margin="0,0,14,0" MinWidth="120">
                                        <ComboBoxItem Content="Bar"/>
                                        <ComboBoxItem Content="Solid fill"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- BAR COLOUR — split at the 50 mark: accent above, dim shade below. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="BAR COLOUR"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,8"
                                           Text="The brightness bar runs 0..100. The right half (50–100) uses your Windows accent — that's where the OS's own brightness slider lives. The left half (0–50) shifts to a darker shade so you get a clear visual cue when you're pushing brightness BELOW the OS minimum, into Underlit's extended-dim range. There's a single transition at the 50 mark — not a per-step gradient. Choose the dim shade or let it auto-derive from your accent."/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Sub-OS-min colour"/>
                                        <TextBlock x:Name="LblHighColorMode" Style="{StaticResource RowHint}"
                                                   Text="Auto — darkened from your accent."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnPickHighColor" Margin="0,0,8,0" Padding="6"
                                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                                            ToolTip="Pick a custom colour for the sub-OS-min half (0–50)">
                                        <Border x:Name="HighColorSwatch"
                                                Width="32" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnResetHighColor" Margin="0,0,14,0"
                                            Content="Auto" Padding="10,4"
                                            Cursor="Hand"
                                            ToolTip="Reset to auto-derive from accent"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LIQUID GLASS TUNING (active when Backdrop = Liquid Glass) -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="LIQUID GLASS"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,8"
                                           Text="Knobs to dial in the look. Press a hotkey while sliding to preview."/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Live capture"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="On: glass refracts what's behind in real time. Windows 11 22H2/23H2 shows a brief yellow capture-border indicator while the OSD is visible. Off: a single snapshot is taken when the OSD appears (frozen for ~1.3s) — no yellow border on any Windows version."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" x:Name="ChkGlassLiveCapture" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Tint color"/>
                                    <Button Grid.Column="1" x:Name="BtnPickTint" Margin="0,0,14,0" Padding="6"
                                            Cursor="Hand" Background="Transparent" BorderThickness="0">
                                        <Border x:Name="TintSwatch"
                                                Width="32" Height="22" CornerRadius="4"
                                                BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"/>
                                    </Button>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Tint strength"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassTintStrength"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassTintStrength, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Light angle"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassLightAngle"
                                            Minimum="-180" Maximum="180"
                                            VerticalAlignment="Center"
                                            TickFrequency="15" IsSnapToTickEnabled="False"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassLightAngle, Path=Value, StringFormat={}{0:F0}°}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Light intensity"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassLightIntensity"
                                            Minimum="0" Maximum="200" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassLightIntensity, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Refraction"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRefraction"
                                            Minimum="0" Maximum="30" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRefraction, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Depth"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassDepth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassDepth, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Dispersion"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassDispersion"
                                            Minimum="0" Maximum="10" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassDispersion, Path=Value, StringFormat={}{0:F1}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Frost"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassFrost"
                                            Minimum="0" Maximum="30" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassFrost, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Corner radius"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassCornerRadius"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassCornerRadius, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Bevel width"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassBevelWidth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassBevelWidth, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Bevel depth"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassBevelDepth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassBevelDepth, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim brightness"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimBrightness"
                                            Minimum="0" Maximum="300" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimBrightness, Path=Value, StringFormat={}{0:F0}}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim width"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimWidth"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimWidth, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>

                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Rim secondary"/>
                                    <Slider Grid.Column="1" x:Name="SldGlassRimSecondary"
                                            Minimum="0" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Text="{Binding ElementName=SldGlassRimSecondary, Path=Value, StringFormat={}{0:F0}%}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- HOTKEYS -->
                    <StackPanel x:Name="PageHotkeys" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Hotkeys"/>
                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,16"
                                   Text="Click a field, then press the key combination you want — Underlit captures it directly. Esc cancels, Backspace clears. Bindings need at least one modifier (Ctrl, Alt, Shift, or Win) so a single key isn't hijacked system-wide."/>

                        <TextBlock Style="{StaticResource CardCaption}" Text="BRIGHTNESS"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness down"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness up"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="WARMTH"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmer"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkWrDown" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Cooler"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkWrUp" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="OTHER"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Boost"/>
                                        <TextBlock Style="{StaticResource RowHint}" Text="Toggle: once jumps to full, again restores."/>
                                    </StackPanel>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkBoost" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Toggle Underlit on/off"/>
                                    <ui:HotkeyField Grid.Column="1" x:Name="TxtHkToggle" MinWidth="220" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- SCHEDULE -->
                    <StackPanel x:Name="PageSchedule" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Schedule"/>

                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,12"
                                   Text="Two ways to control warmth: turn the toggle ON to let Underlit follow the day/night ramp below — your screen auto-warms in the evening and resets to neutral in the morning, applied immediately on launch. Turn the toggle OFF to control warmth manually with hotkeys; whatever you set persists across sessions until you change it again."/>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Warmth follows a schedule"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="Override automatically every 30 seconds while running."/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" x:Name="ChkScheduleEnabled" Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Schedule curve cards — dimmed/disabled when the toggle above is off so the
                             user gets a clear signal that they're inert in manual mode. IsEnabled
                             binding handles the disable state; Opacity binding handles the visual cue. -->
                        <StackPanel x:Name="SchedulePanelCurve"
                                    IsEnabled="{Binding ElementName=ChkScheduleEnabled, Path=IsChecked}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ChkScheduleEnabled, Path=IsChecked}" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                        <!-- ====== PROFILE PICKER ======
                             Apple-style: a thin pill row with the active profile in a dropdown,
                             flanked by + (clone current → new profile) and − (delete; disabled
                             on the built-in "Recommended" profile). The profile drives the
                             Bedtime / WakeTime / Night warmth values below. Switching profiles
                             instantly retargets the curve. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="PROFILE"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="CboProfile"
                                              Margin="14,0,8,0"
                                              VerticalAlignment="Center"
                                              MinWidth="200"
                                              IsEditable="False"/>
                                    <Button Grid.Column="1" x:Name="BtnRenameProfile"
                                            Margin="0,0,4,0" Padding="6,4"
                                            Cursor="Hand" Background="Transparent"
                                            BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"
                                            ToolTip="Rename this profile">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE70F;"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnAddProfile"
                                            Margin="0,0,4,0" Padding="6,4"
                                            Cursor="Hand" Background="Transparent"
                                            BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"
                                            ToolTip="Clone current profile to a new one">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE710;"/>
                                    </Button>
                                    <Button Grid.Column="3" x:Name="BtnRemoveProfile"
                                            Margin="0,0,14,0" Padding="6,4"
                                            Cursor="Hand" Background="Transparent"
                                            BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"
                                            ToolTip="Delete this profile (disabled for Recommended)">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource App.TextPrimary}"
                                                   Text="&#xE738;"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ====== DAY/NIGHT CURVE (read-only graph, derived from Bedtime + WakeTime) ======
                             Drag-to-edit landed in v0.6.23+ as a planned follow-up; for now the
                             curve is auto-derived from the active profile's two anchor times via
                             the circadian-physiology model. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="DAY/NIGHT CURVE"/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <StackPanel>
                                <Grid Margin="14,12,14,8" Height="120">
                                    <Canvas x:Name="ScheduleGraph" ClipToBounds="True"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ====== BEDTIME + WAKE TIME ======
                             The two anchor times that drive the entire schedule curve.
                             Internally we expand them into the legacy 4-field ramp window
                             (BedtimeStart = Bed − 2.5h, WakeupStart = Wake − 0.75h, etc.)
                             so Scheduler.ComputeWarmth keeps working without changes. -->
                        <TextBlock Style="{StaticResource CardCaption}" Text="TIMES"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Bedtime"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="Underlit reaches deep warmth by this time. Evening ramp starts ~2.5 h earlier."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtBedtime" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowLabel}" Text="Wake time"/>
                                        <TextBlock Style="{StaticResource RowHint}"
                                                   Text="Underlit returns to neutral by this time. Morning ramp starts ~45 min earlier."/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="TxtWakeTime" Style="{StaticResource AppleTextBox}" Width="80" Margin="0,0,14,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource CardCaption}" Text="NIGHT WARMTH"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmth at night (K)"/>
                                    <Slider Grid.Column="1" x:Name="SldNightWarmth" Style="{StaticResource AppleSlider}"
                                            Minimum="1500" Maximum="6500" TickFrequency="100" IsSnapToTickEnabled="True"/>
                                    <!-- Live preview: shows the actual screen tint produced at the
                                         selected kelvin, updated as the user drags the slider. -->
                                    <Border Grid.Column="2" x:Name="NightWarmthPreview"
                                            Margin="8,0,8,0" Width="32" Height="22" CornerRadius="4"
                                            BorderBrush="{DynamicResource App.CardBorder}" BorderThickness="1"
                                            ToolTip="Preview of the screen tint at this kelvin"/>
                                    <TextBlock Grid.Column="3" Style="{StaticResource ValueChip}" x:Name="LblNightWarmth"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        </StackPanel>  <!-- /SchedulePanelCurve -->
                    </StackPanel>

                    <!-- MONITORS -->
                    <StackPanel x:Name="PageMonitors" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Monitors"/>
                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,16"
                                   Text="Per-monitor offsets are ADDED to the global brightness and warmth. Handy for a main monitor that's physically much brighter than a secondary."/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <ListView x:Name="LstMonitors" Background="Transparent" BorderThickness="0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Display" Width="200" DisplayMemberBinding="{Binding DeviceName}"/>
                                        <GridViewColumn Header="Path" Width="100" DisplayMemberBinding="{Binding Path}"/>
                                        <GridViewColumn Header="Brightness offset" Width="140" DisplayMemberBinding="{Binding BrightnessOffset}"/>
                                        <GridViewColumn Header="Warmth offset (K)" Width="140" DisplayMemberBinding="{Binding WarmthOffset}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                        <TextBlock Style="{StaticResource CardCaption}" Text="ADJUST SELECTED MONITOR"/>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Brightness offset"/>
                                    <Slider Grid.Column="1" x:Name="SldMonBrOffset" Style="{StaticResource AppleSlider}"
                                            Minimum="-50" Maximum="50" TickFrequency="5"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblMonBr"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Style="{StaticResource Row}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource RowLabel}" Text="Warmth offset (K)"/>
                                    <Slider Grid.Column="1" x:Name="SldMonWrOffset" Style="{StaticResource AppleSlider}"
                                            Minimum="-2000" Maximum="0" TickFrequency="100"/>
                                    <TextBlock Grid.Column="2" Style="{StaticResource ValueChip}" x:Name="LblMonWr"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- EXCLUSIONS -->
                    <StackPanel x:Name="PageExclusions" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource PageTitle}" Text="Exclusions"/>
                        <TextBlock Style="{StaticResource RowHint}" Margin="0,0,0,16"
                                   Text="When any of these apps is focused, Underlit suspends its dimming. Enter process names WITHOUT the .exe — one per line."/>
                        <Border Style="{StaticResource Card}" Padding="4">
                            <TextBox x:Name="TxtExclusions"
                                     Style="{StaticResource AppleTextBox}"
                                     MinHeight="240"
                                     HorizontalAlignment="Stretch"
                                     Margin="0"
                                     FontFamily="Cascadia Mono, Consolas"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
